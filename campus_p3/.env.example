# 必填：使用 `openssl rand -hex 32` 等方式生成，不要提交真实值。
DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

POSTGRES_DB=p3_resource_student
POSTGRES_USER=p3
POSTGRES_PASSWORD=p3_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

P1_CLIENT_MODE=mock
# Docker 容器访问宿主机 P1；同一 Compose 网络时改为对应服务名。
P1_BASE_URL=http://host.docker.internal:8101/api/ai/v1
P1_TIMEOUT_SECONDS=10
P1_SERVICE_ID=p3-service
P1_AUTH_TOKEN=
# 留空时使用学生请求中的 P3 地址；P1 与 P3 同网络时可设为 http://p3-api:8103。
P1_FILE_BASE_URL=
P1_FILE_URL_TTL_SECONDS=3600
P1_RECOGNITION_START_GRACE_SECONDS=30

WRONG_QUESTION_MAX_FILE_SIZE=10485760
WRONG_QUESTION_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp
